    "startMs": 505909
  },
  {
    "speaker": {
      "id": "matti-nieminen",
      "name": "Matti Nieminen",
      "type": "host",
      "avatar": "avatar-4.png"
    },
    "line": "Totta. Ja teille kuulijoille kans, muistakaa...<|prosody:pause|> pysykää hereillä. Älkää uskoko ihan kaikkee mitä Yle teille syöttää.",
