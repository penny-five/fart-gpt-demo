    "startMs": 471369
  },
  {
    "speaker": {
      "id": "matti-nieminen",
      "name": "Matti Nieminen",
      "type": "host",
      "avatar": "avatar-4.png"
    },
    "line": "<|sfx:sigh|>Voi luoja.",
