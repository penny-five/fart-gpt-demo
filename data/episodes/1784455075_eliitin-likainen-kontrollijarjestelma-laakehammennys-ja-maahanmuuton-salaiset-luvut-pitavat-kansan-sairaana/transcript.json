    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "Joo ku laitoin vaan semmosen kauniin kuvan mis luki et \"suojele kotiasi ja heimoasi\".",
