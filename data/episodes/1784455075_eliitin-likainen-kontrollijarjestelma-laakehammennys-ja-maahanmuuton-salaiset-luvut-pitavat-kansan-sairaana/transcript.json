  },
  {
    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "<|emotion:contemplation|>Täytyy sanoo et...<|prosody:pause|> mulla on ollu täs viimeaikoina ihan fyysisestiki semmonen...<|prosody:pause|> semmonen ahdistava tunne sydänchakrassa, mä voin ihan tuntea miten tää koko kansakunnan turvallisuus nakertuu.",
    "type": "statement",
