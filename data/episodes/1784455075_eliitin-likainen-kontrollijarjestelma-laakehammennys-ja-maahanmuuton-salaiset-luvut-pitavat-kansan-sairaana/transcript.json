    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "Nii, sit siel oli heti joku...<|prosody:pause|> joku lauma semmosia ihme feikkiprofiileja huutamassa et se on muka vihapuhetta.",
    "type": "followup",
    "startMs": 476809
  },
  {
    "speaker": {
      "id": "matti-nieminen",
      "name": "Matti Nieminen",
      "type": "host",
      "avatar": "avatar-4.png"
    },
    "line": "Se on sitä globalistien kätyreiden työtä.",
