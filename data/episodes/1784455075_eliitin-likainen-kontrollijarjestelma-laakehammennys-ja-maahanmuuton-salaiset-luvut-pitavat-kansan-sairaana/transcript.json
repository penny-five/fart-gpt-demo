    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "Joo, ne yrittää nujertaa kaiken...<|prosody:pause|> kaiken aidon ja alkuperäisen.",
