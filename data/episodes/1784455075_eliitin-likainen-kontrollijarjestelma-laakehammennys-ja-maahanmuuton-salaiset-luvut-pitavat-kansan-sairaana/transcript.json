  },
  {
    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "Vaik en mä ny uutisia aina ees jaksais seurata, ni sen vaan tietää.",
    "type": "followup",
    "startMs": 440204
  },
  {
    "speaker": {
      "id": "matti-nieminen",
      "name": "Matti Nieminen",
      "type": "host",
      "avatar": "avatar-4.png"
    },
    "line": "Se sun intuitio osuu kyl ihan oikeeseen täs asiassa.",
    "type": "dialogue",
    "startMs": 444644
  },
  {
    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "Kyl se useimmiten osuu.",
    "type": "dialogue",
    "startMs": 448058
  },
  {
    "speaker": {
      "id": "matti-nieminen",
      "name": "Matti Nieminen",
      "type": "host",
      "avatar": "avatar-4.png"
    },
    "line": "Täs on tää valtiontalouden prioriteetit ollu vuosia ihan nurinkurin...<|prosody:pause|> Omat unohdetaa ja kansainvälisille velvoitteille pokkuroitaa.",
    "type": "statement",
    "startMs": 449837
  },
  {
    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "Joo.",
