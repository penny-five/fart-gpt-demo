    "startMs": 458397
  },
  {
    "speaker": {
      "id": "pirjo-harmaja",
      "name": "Pirjo Harmaja",
      "type": "guest",
      "avatar": "avatar-5.png"
    },
    "line": "Hyvä et joku uskaltaa, ku mullaki...<|prosody:pause|> no, mä sain Instagramissa ihan hirveen vihamyrskyn päälleni.",
    "type": "statement",
    "startMs": 464729
  },
  {
    "speaker": {
      "id": "matti-nieminen",
      "name": "Matti Nieminen",
      "type": "host",
      "avatar": "avatar-4.png"
    },
    "line": "Ai ihan oikeesti?",
